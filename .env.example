# MongoDB Connection String (use dayframe_v2 for clean DB)
MONGODB_URI="mongodb://localhost:27017/dayframe"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Tauri desktop: optional override when the app is not on localhost (defaults to NEXT_PUBLIC_APP_URL)
# TAURI_APP_URL="http://localhost:3000"
NEXT_PUBLIC_IMAGE_HOSTS="images.unsplash.com,cdn.pixabay.com,staticflickr.com"

# Authentication
# In production, use a strong random string: `openssl rand -base64 32`
AUTH_SECRET="your_auth_secret_here"
CRON_SECRET="set_a_random_token_here"

# DB Encryption-at-Rest (Envelope Encryption)
# JSON map of key-id -> 32-byte base64 key. Generate with: `openssl rand -base64 32`
DB_ENCRYPTION_ACTIVE_KID="v1"
DB_ENCRYPTION_KEYRING_JSON={"v1":"replace_with_base64_32byte_key"}

# OAuth Providers
# You need to set these up in Google Cloud Console
AUTH_GOOGLE_ID="your_google_client_id"
AUTH_GOOGLE_SECRET="your_google_client_secret"

# Gmail SMTP (Alternative for sending to anyone without verified domain)
# 1. Enable 2-Step Verification in your Google Account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Create a new App Password (name it "Dayframe")
# 4. Paste the 16-character password below (spaces don't matter)
GMAIL_USER="your.email@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# Rate Limiting (Production)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Seed Configuration
SEED=true
# Set to "true" to allow the seed script to run during production builds
SEED_ALLOW_PROD="true"
ADMIN_EMAIL="admin@example.com"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="password123"
