{
  "name": "dayframe",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run seed && next dev",
    "build": "next build",
    "start": "next start",
    "seed": "ts-node -r dotenv/config --compiler-options \"{\\\"module\\\":\\\"commonjs\\\"}\" scripts/seed.ts",
    "lint": "eslint",
    "lint:ci": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "tauri:dev": "concurrently --kill-others \"next dev --port 3000\" \"wait-on http://localhost:3000 && tauri dev\"",
    "tauri:build": "next build && tauri build"
  },
