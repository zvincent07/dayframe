{
  "name": "dayframe",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run seed && next dev",
    "build": "npm run seed && cross-env NODE_OPTIONS=--max_old_space_size=8192 next build",
    "start": "next start",
    "seed": "ts-node -r dotenv/config --compiler-options \"{\\\"module\\\":\\\"commonjs\\\"}\" scripts/seed.ts",
    "migrate:db-encryption": "ts-node -r dotenv/config --compiler-options \"{\\\"module\\\":\\\"commonjs\\\"}\" scripts/migrate-db-encryption.ts",
    "lint": "eslint",
    "lint:ci": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "tauri:dev": "concurrently --kill-others \"next dev --port 3000\" \"wait-on http://localhost:3000 && tauri dev\"",
    "tauri:build": "npm run seed && cross-env NODE_OPTIONS=--max_old_space_size=8192 next build && tauri build"
  },
  "dependencies": {
    "@auth/core": "0.41.1",
    "@hello-pangea/dnd": "^18.0.1",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@tailwindcss/typography": "^0.5.19",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "lucide-react": "^0.574.0",
    "mongoose": "^8.5.0",
    "next": "15.5.4",
    "next-auth": "5.0.0-beta.30",
    "next-themes": "^1.0.0-beta.0",
    "nodemailer": "^6.9.13",
    "open-graph-scraper": "^6.3.8",
    "otpauth": "^9.5.0",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "19.0.0",
    "react-day-picker": "^9.13.2",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.71.1",
    "react-markdown": "^9.1.0",
    "recharts": "^2.12.7",
    "remark-gfm": "^4.0.1",
    "resend": "^6.9.2",
    "rss-parser": "^3.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^6.4.14",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "eslint": "^9.9.0",
    "eslint-config-next": "15.5.4",
    "jsdom": "^24.0.0",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.0.0",
    "ts-node": "^10.9.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "wait-on": "^7.0.1"
  }
}
